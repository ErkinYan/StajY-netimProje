@model List<AcademicYear>
@{
    Layout = "_IlceLayout";
    ViewData["Title"] = "Eğitim Öğretim Yılı Yönetimi";
    ViewData["ActiveMenu"] = "YilYonetim";
    ViewData["TopbarTitle"] = "Eğitim Öğretim Yılı Yönetimi";
    var selectedYearId = (int)(ViewData["SelectedYearId"] ?? 0);
}

<div class="content">
    <div class="layout">
        <div class="card">
            <div class="card-header"><h3>Yeni Eğitim Yılı Oluştur</h3><p>Yeni yıl sistemdeki tüm okullar için oluşturulur</p></div>
            <div class="card-body">
                <div class="warn-box">⚠ Yeni yıl aktifleştirildiğinde mevcut aktif yıl otomatik olarak <strong>geçmiş</strong> durumuna geçer.</div>
                <form asp-action="CreateYear" asp-controller="Dashboard" method="post" id="yearForm">
                    @Html.AntiForgeryToken()
                    <div class="field"><label>Yıl Adı</label><input type="text" name="yearName" id="yilAdi" placeholder="Örn: 2026-2027" required></div>
                    <div class="field-row">
                        <div class="field"><label>Başlangıç Tarihi</label><input type="date" name="startDate" id="yilBaslangic" value="2026-09-01"></div>
                        <div class="field"><label>Bitiş Tarihi</label><input type="date" name="endDate" id="yilBitis" value="2027-06-30"></div>
                    </div>
                    <button class="btn btn-primary" type="submit">Yılı Oluştur ve Aktifleştir</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <div>
                    <h3>Tüm Eğitim Öğretim Yılları</h3>
                    <p>Bir yılı seçtiğinizde Dashboard, Okullar ve Müdür Atama o yıla göre gösterilir.</p>
                </div>
                <form asp-action="UseActiveYear" asp-controller="Dashboard" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-ghost btn-sm" type="submit">Aktif Yıla Dön</button>
                </form>
            </div>
            <div class="yil-list" style="padding:14px">
                @foreach (var year in Model)
                {
                    <div class="yil-card @(year.IsActive ? "aktif" : "gecmis")" style="border:1.5px solid var(--border);border-radius:10px;padding:14px 16px;display:flex;align-items:center;gap:14px;margin-bottom:10px;@(year.IsActive ? "background:#F2FCF7" : "opacity:.75")">
                        <div class="yil-icon" style="width:42px;height:42px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:20px;background:@(year.IsActive ? "#E8F8F1" : "#F0F1F5")">@(year.IsActive ? "📅" : "📁")</div>
                        <div class="yil-info" style="flex:1">
                            <div class="yil-name" style="font-size:14px;font-weight:700">@year.Name</div>
                            <div class="yil-dates" style="font-size:12px;color:var(--muted);margin-top:2px">@year.StartDate.ToString("dd.MM.yyyy") — @year.EndDate.ToString("dd.MM.yyyy")</div>
                        </div>
                        <div class="yil-actions">
                            @if (year.IsActive)
                            {
                                <span class="badge badge-green">● Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-gray">Geçmiş</span>
                            }
                            @if (selectedYearId == year.Id)
                            {
                                <span class="badge badge-gold" style="margin-left:6px">Görüntüleniyor</span>
                            }
                            else
                            {
                                <form asp-action="SetViewedYear" asp-controller="Dashboard" method="post" style="display:inline-block;margin-left:6px">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="yearId" value="@year.Id" />
                                    <button class="btn btn-ghost btn-sm" type="submit">Bu Yılı Görüntüle</button>
                                </form>
                            }
                        </div>
                    </div>
                }
                @if (Model.Count == 0)
                {
                    <div class="empty"><p>Henüz eğitim öğretim yılı bulunmuyor.</p></div>
                }
            </div>
        </div>
    </div>
</div>

@if (TempData["Toast"] is string toast && !string.IsNullOrWhiteSpace(toast))
{
    <div class="toast show" id="toast">@toast</div>
}
else
{
    <div class="toast" id="toast"></div>
}
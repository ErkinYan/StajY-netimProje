@model StajYonetim.Identity.Models.AccountViewModels.RegisterDistrictViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>İlçe Kayıt | Staj Yönetim Sistemi</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    /* Minimal inline styling derived from provided mockup to keep view self-contained. */
    body { font-family: 'DM Sans', sans-serif; background:#f5f0e8; margin:0; }
    .container { display:flex; min-height:100vh; }
    .left-panel { width:42%; background:#0d1b2a; color:#fff; padding:48px; box-sizing:border-box; }
    .right-panel { flex:1; padding:48px; box-sizing:border-box; }
    .form-container { max-width:560px; margin:0 auto; background:#fff; padding:24px; border-radius:8px; }
    label { display:block; font-size:12px; margin-bottom:6px; color:#556; }
    input, select { width:100%; padding:10px 12px; margin-bottom:12px; border:1px solid #ddd; border-radius:6px; }
    .btn-submit { background:#0d1b2a; color:#fff; padding:12px 16px; border:none; border-radius:8px; cursor:pointer; }
    .error { color:#c0392b; font-size:13px; margin-bottom:12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="left-panel">
      <h1>Staj Yönetim Sistemi</h1>
      <p style="max-width:300px;">Okullar, öğretmenler, öğrenciler ve işletmeler — hepsi tek platformda, yıl bazlı kayıt altında.</p>
    </div>
    <div class="right-panel">
      <div class="form-container">
        <h2>İlçe Kaydı</h2>
        <p>İlçe hesabınızı oluşturmak için formu doldurun.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error">Lütfen formu kontrol edin ve eksikleri tamamlayın.</div>
        }

        <form asp-action="RegisterDistrict" asp-controller="Account" method="post">
          @Html.AntiForgeryToken()

          <label for="IlceAdi">İlçe Adı</label>
          <input asp-for="IlceAdi" id="IlceAdi" />
          <span asp-validation-for="IlceAdi" class="error"></span>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
              <label for="YetkiliAd">Yetkili Ad</label>
              <input asp-for="YetkiliAd" id="YetkiliAd" />
              <span asp-validation-for="YetkiliAd" class="error"></span>
            </div>
            <div>
              <label for="YetkiliSoyad">Yetkili Soyad</label>
              <input asp-for="YetkiliSoyad" id="YetkiliSoyad" />
              <span asp-validation-for="YetkiliSoyad" class="error"></span>
            </div>
          </div>

          <label for="Email">E-posta</label>
          <input asp-for="Email" id="Email" />
          <span asp-validation-for="Email" class="error"></span>

          <label for="TcKimlikNo">TC Kimlik No</label>
          <input asp-for="TcKimlikNo" id="TcKimlikNo" inputmode="numeric" maxlength="11" placeholder="12345678901" />
          <span asp-validation-for="TcKimlikNo" class="error"></span>

          <label for="Telefon">Telefon</label>
          <input asp-for="Telefon" id="Telefon" />
          <span asp-validation-for="Telefon" class="error"></span>

          <label for="Password">Şifre</label>
          <input asp-for="Password" id="Password" type="password" />
          <span asp-validation-for="Password" class="error"></span>

          <label for="ConfirmPassword">Şifre Tekrar</label>
          <input asp-for="ConfirmPassword" id="ConfirmPassword" type="password" />
          <span asp-validation-for="ConfirmPassword" class="error"></span>

          <div style="margin:12px 0;">
            <input asp-for="Kvkk" id="kvkk" type="checkbox" /> <label for="kvkk">KVKK ve kullanım koşullarını kabul ediyorum</label>
            <span asp-validation-for="Kvkk" class="error"></span>
          </div>

          <button type="submit" class="btn-submit">Kaydı Tamamla</button>
        </form>
      </div>
    </div>
  </div>
  <script src="/lib/jquery/dist/jquery.min.js"></script>
  <script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
  <script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

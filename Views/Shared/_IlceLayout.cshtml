@{
    Layout = null;
    var activeMenu = (ViewData["ActiveMenu"] as string) ?? "Dashboard";
    var topbarTitle = (ViewData["TopbarTitle"] as string) ?? "İlçe Paneli";
    var yearText = (ViewData["YearText"] as string) ?? "2025 – 2026 Aktif Yıl";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@topbarTitle - Staj Yönetim</title>
    <link rel="stylesheet" href="/css/ilce.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Nunito:wght@300;400;500;600;700&display=swap" />
</head>
<body>
<aside class="sidebar">
    <div class="sb-logo">
        <div class="app-name">Okul Yönetim<br>Sistemi</div>
        <span class="role-badge">İlçe Yönetimi</span>
    </div>
    <nav class="sb-nav">
        <div class="sb-section">Genel</div>
        <a href="/Dashboard/Index" class="sb-link @(activeMenu == "Dashboard" ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
        <div class="sb-section">Yönetim</div>
        <a href="/Dashboard/Okullar" class="sb-link @(activeMenu == "Okullar" ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Okullar
        </a>
        <a href="/Dashboard/MudurAta" class="sb-link @(activeMenu == "MudurAta" ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Müdür Atama
        </a>
        <a href="/Dashboard/YilYonetim" class="sb-link @(activeMenu == "YilYonetim" ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Yıl Yönetimi
        </a>
        <div class="sb-section">Raporlar</div>
        <a href="/Dashboard/Profil" class="sb-link @(activeMenu == "Profil" ? "active" : "")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Profil
        </a>
    </nav>
    <div class="sb-bottom">
        <div class="sb-user">
            <div class="sb-avatar">@(ViewData["CurrentUserInitial"] ?? "K")</div>
            <div>
                <div class="sb-user-name">@(ViewData["CurrentUserFullName"] ?? "Kullanıcı")</div>
                <div class="sb-user-role">@(ViewData["CurrentUserRole"] ?? "İlçe Yöneticisi")</div>
            </div>
        </div>
        <form asp-action="Logout" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="sb-logout">↩ Çıkış Yap</button>
        </form>
    </div>
</aside>

<div class="main">
    <div class="topbar">
        <span class="topbar-title">@topbarTitle</span>
        <div class="topbar-right">
            <span class="year-badge"><span class="year-dot"></span>@yearText</span>
        </div>
    </div>
    @RenderBody()
</div>
</body>
</html>
